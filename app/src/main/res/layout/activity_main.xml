<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestor de Motor TTS (AI / LLM)"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voces por defecto: 
1. Español Chileno (Mujer)
2. Español Chileno (Hombre)"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnRecordVoice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grabar/Subir 30s de audio para Clonación"/>

    <Button
        android:id="@+id/btnProcessCloning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Procesar y Guardar Voz Clonada"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Para usar este motor, ve a la configuración de Android -> Accesibilidad -> Text-to-speech y selecciona 'AI LLM Chilean TTS'."
        android:layout_marginTop="32dp"
        android:textSize="14sp"
        android:textColor="#555555" />

</LinearLayout>